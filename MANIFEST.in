recursive-include modules *.c *.h *.inc *.S *.cdef *.proto
include packaging/build_ffi.py
include packaging/discovery.py
include packaging/generate_protos.py
prune modules/*/python/test

# setuptools-scm's file finder sweeps every git-tracked tree into the sdist;
# drop these, then re-add only the BLAKE3 sources the build needs.
prune external/unity
prune external/blake3
prune .github

# BLAKE3's C sources are compiled into the extension, so they must ship in the
# sdist; the submodule has to be checked out at build time. Unity stays out: it
# is test-only.
include external/blake3/c/*.c
include external/blake3/c/*.h
include external/blake3/c/*.S
include external/blake3/LICENSE_A2 external/blake3/LICENSE_A2LLVM external/blake3/LICENSE_CC0
include NOTICE
include AUTHORS.md
include CHANGELOG.md
